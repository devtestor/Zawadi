# =============================================================================
# ALCURRY production env — canonical template for /opt/alcurry/.env on the VPS.
#
# Workflow:
#   1. Copy this file to the VPS as /opt/alcurry/.env (mode 600, owner alcurry).
#   2. Fill in every value that isn't "leave empty unless used".
#   3. Re-deploy: ./scripts/deploy.sh  (or just push to main and let CI run).
#
# Generate strong secrets with:  openssl rand -base64 32
# Anything left blank that the backend treats as required will refuse to boot.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. DEPLOY METADATA — read by docker-compose.prod.yml and scripts/deploy.sh
# -----------------------------------------------------------------------------
# Public hostnames. Must match the Cloudflare A records and the GitHub repo
# variables API_DOMAIN / WEB_DOMAIN.
API_DOMAIN=api.alcurry.app
WEB_DOMAIN=alcurry.app

# Tells `docker compose pull` which image stream to fetch. MUST be lowercase
# (GHCR rejects uppercase image tags). Even if your GitHub org/repo has
# uppercase letters (e.g. devtestor/Zawadi), use the lowercase form here:
GITHUB_REPO=devtestor/zawadi

# CI bumps this to the commit SHA on every deploy. Leave as `latest` for the
# initial bring-up.
IMAGE_TAG=latest

# Optional: log in to GHCR (only needed if the repo is private).
# Generate at https://github.com/settings/tokens with the read:packages scope.
GHCR_USER=
GHCR_TOKEN=


# -----------------------------------------------------------------------------
# 2. RUNTIME — backend container envs (NODE_ENV / PORT are set in compose)
# -----------------------------------------------------------------------------
# trace | debug | info | warn | error  (default: info)
LOG_LEVEL=info


# -----------------------------------------------------------------------------
# 3. DATABASE — self-hosted Postgres in docker-compose.prod.yml
# -----------------------------------------------------------------------------
# These three are consumed by the `db` service AND assembled into DATABASE_URL
# inside the backend env block in docker-compose.prod.yml. Don't override
# DATABASE_URL here unless you've removed the bundled `db` service.
POSTGRES_USER=alcurry
# Use hex (URL-safe) — base64 contains `/` `+` `=` which break Prisma's
# DATABASE_URL parser. Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=replace-with-openssl-rand-hex-24
POSTGRES_DB=alcurry

# DATABASE_PROVIDER is forced to "postgresql" in compose; leaving it commented
# is correct. Only set if you point DATABASE_URL at a managed Postgres host
# (Neon / Linode Managed DB / Supabase).
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://USER:PASS@HOST:5432/alcurry?schema=public&sslmode=require


# -----------------------------------------------------------------------------
# 4. AUTH (Better Auth) — REQUIRED
# -----------------------------------------------------------------------------
# 32-byte secret. Rotate => every active session is invalidated.
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32


# -----------------------------------------------------------------------------
# 5. EMAIL (Resend) — REQUIRED for sign-in OTP
# -----------------------------------------------------------------------------
# https://resend.com/api-keys — Full Access scope.
RESEND_API_KEY=re_replace_me

# After verifying alcurry.app in Resend, switch to the no-reply alias.
# Sandbox value: "ALCURRY <onboarding@resend.dev>"
# NOTE: quote the value — angle brackets are bash redirection operators and
# `scripts/deploy.sh` sources this file with `set -a; source .env`.
EMAIL_FROM="ALCURRY <no-reply@alcurry.app>"


# -----------------------------------------------------------------------------
# 6. STORAGE (Cloudflare R2 — S3-compatible) — REQUIRED for image uploads
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=s3
S3_REGION=auto
S3_BUCKET=alcurry-prod

# https://<account-id>.r2.cloudflarestorage.com  (account ID at top of R2 UI)
S3_ENDPOINT=https://REPLACE_WITH_R2_ACCOUNT_ID.r2.cloudflarestorage.com

S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me

# Public base URL for uploaded files. Start with the auto-generated R2
# subdomain, swap to https://cdn.alcurry.app once you wire that custom domain.
S3_PUBLIC_URL=https://pub-REPLACE_ME.r2.dev


# -----------------------------------------------------------------------------
# 7. PESAPAL (boost payments + wallet top-ups) — leave blank to disable
# -----------------------------------------------------------------------------
# Sandbox base: https://cybqa.pesapal.com/pesapalv3
# Prod base:    https://pay.pesapal.com/v3
PESAPAL_BASE_URL=https://cybqa.pesapal.com/pesapalv3
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=

# KES | UGX | TZS | RWF | USD
PESAPAL_CURRENCY=KES

# Registered IPN listener UUID (created once via Pesapal API or dashboard).
PESAPAL_IPN_ID=


# -----------------------------------------------------------------------------
# 8. SMS / WHATSAPP — phone verification fallback
# -----------------------------------------------------------------------------
# console | twilio | whatsapp     (default: console — logs the OTP only)
SMS_PROVIDER=console

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# WhatsApp Cloud (Meta)
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=


# -----------------------------------------------------------------------------
# 9. FX RATES — free public source, override only if rate-limited
# -----------------------------------------------------------------------------
FX_API_URL=https://open.er-api.com/v6/latest/USD


# -----------------------------------------------------------------------------
# 10. ERROR TRACKING (Sentry) — optional
# -----------------------------------------------------------------------------
SENTRY_DSN=


# -----------------------------------------------------------------------------
# 11. AI ASSISTANTS (OpenAI) — optional, used for listing copy + voice search
# -----------------------------------------------------------------------------
OPENAI_API_KEY=


# -----------------------------------------------------------------------------
# 12. IMAGE MODERATION (Sightengine) — optional
# -----------------------------------------------------------------------------
SIGHTENGINE_USER=
SIGHTENGINE_SECRET=


# -----------------------------------------------------------------------------
# 13. VIDEO ROOMS (LiveKit) — optional, tour calls
# -----------------------------------------------------------------------------
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=


# -----------------------------------------------------------------------------
# 14. GEO + SANCTIONS — optional
# -----------------------------------------------------------------------------
IPINFO_TOKEN=

# none | opensanctions | csv
SANCTIONS_PROVIDER=none
OPENSANCTIONS_API_KEY=
SANCTIONS_CSV_URL=


# -----------------------------------------------------------------------------
# 15. ON-CHAIN ESCROW (EVM) — optional. Disabled unless CHAIN_ENABLED=true.
# -----------------------------------------------------------------------------
CHAIN_ENABLED=false
CHAIN_NAME=polygon-amoy
CHAIN_ID=80002
CHAIN_RPC_URL=https://rpc-amoy.polygon.technology

# Platform relayer key. Fund with a few cents of MATIC for testnet/mainnet.
CHAIN_PRIVATE_KEY=

# Factory address from `forge script script/Deploy.s.sol:Deploy --broadcast`.
CHAIN_ESCROW_FACTORY=
CHAIN_EXPLORER_BASE_URL=https://amoy.polygonscan.com


# -----------------------------------------------------------------------------
# 16. WEBHOOKS — exponential-backoff retry config (defaults are fine)
# -----------------------------------------------------------------------------
WEBHOOK_MAX_ATTEMPTS=8
WEBHOOK_BASE_BACKOFF_MS=2000


# -----------------------------------------------------------------------------
# 17. CRON — protects /api/cron/* endpoints from public traffic.
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 24
CRON_SECRET=replace-with-openssl-rand-hex-24


# -----------------------------------------------------------------------------
# 18. MARKETPLACE POLICY KNOBS — sensible defaults, tune for your market.
# -----------------------------------------------------------------------------
# Platform fee on each escrow release, in basis points. 250 = 2.50 %.
PLATFORM_FEE_BPS=250

# Listings priced at or above this USD value need admin approval.
HIGH_VALUE_USD=500000

# KYC required for trades over this USD-equivalent amount.
KYC_REQUIRED_OVER_USD=1000

# TOTP required for withdrawals over this USD amount.
TWOFA_REQUIRED_OVER_USD=5000

# Auto-release escrow N days after the buyer marks "delivered".
HOLDING_PERIOD_DAYS=3

# Currency the in-app wallet defaults to.
WALLET_DEFAULT_CURRENCY=USD

# Seconds appended to an auction's end time whenever a bid lands in the last
# few seconds — prevents sniping.
AUCTION_GRACE_SECONDS=30
