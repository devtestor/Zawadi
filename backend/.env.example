PORT=3000
NODE_ENV=development
BACKEND_URL=http://localhost:3000
LOG_LEVEL=info

# Comma-separated. Supports * as a wildcard. Native callers (Expo) bypass CORS.
ALLOWED_ORIGINS=https://*.zawadi.app,https://zawadi.app
# Comma-separated deep-link schemes for the mobile app
APP_SCHEMES=zawadi://

# SQLite (dev) — for production switch to a Postgres URL e.g.
# DATABASE_URL="postgresql://user:pass@host:5432/zawadi?schema=public"
DATABASE_URL="file:./prisma/dev.db"
DATABASE_PROVIDER=sqlite

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# --- Email (Resend, preferred) ---
# Get a key at https://resend.com/api-keys. Make sure to verify your domain
# (or use the onboarding@resend.dev test sender for development).
# Leave RESEND_API_KEY blank to fall back to the vibecode SMTP relay.
RESEND_API_KEY=
EMAIL_FROM="ZAWADI <no-reply@zawadi.app>"

# --- Storage (S3 / Cloudflare R2 / MinIO) — required ---
STORAGE_PROVIDER=s3
S3_REGION=auto
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base url where uploaded files are served from (e.g. R2 custom domain)
S3_PUBLIC_URL=

# --- SMS (Twilio for phone verification) ---
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- FX rates (free, no key required) ---
FX_API_URL=https://open.er-api.com/v6/latest/USD

# --- Optional: error tracking ---
SENTRY_DSN=

# --- Optional: AI listing assistant ---
OPENAI_API_KEY=

# --- Pesapal (boost payments) ---
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
# Sandbox: https://cybqa.pesapal.com/pesapalv3 ; production: https://pay.pesapal.com/v3
PESAPAL_BASE_URL=https://cybqa.pesapal.com/pesapalv3
PESAPAL_CURRENCY=RWF
PESAPAL_IPN_ID=
