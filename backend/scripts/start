#!/bin/bash
set -o errexit
set -o nounset
set -o pipefail

# Load shared environment setup
source "$(dirname "$0")/env.sh"

# Backup the database before proceeding (SQLite only).
if [[ "${ENVIRONMENT}" == "production" ]] && [[ -f "${DATABASE_FILE:-}" ]]; then
  DATABASE_BACKUP_FILE="${DATABASE_FILE}-$(date +%s)"
  echo "VACUUM INTO '${DATABASE_BACKUP_FILE}'" | sqlite3 "${DATABASE_FILE}"
fi

# Install dependencies
echo "Installing dependencies..."
bun install

# Generate Prisma client and apply schema
if [ -f "prisma/schema.prisma" ]; then
  echo "Generating Prisma client..."
  bunx prisma generate
  if [[ "${ENVIRONMENT}" == "production" ]]; then
    echo "Applying migrations..."
    bunx prisma migrate deploy || bunx prisma db push --accept-data-loss
  else
    echo "Pushing schema to dev database..."
    bunx prisma db push --accept-data-loss
  fi
fi

# Start server. Use exec so signals propagate to bun.
if [[ "${ENVIRONMENT}" == "production" ]]; then
  echo "Starting server in production mode..."
  exec bun src/index.ts
else
  echo "Starting server in dev mode with hot reload..."
  exec bun --hot src/index.ts
fi
