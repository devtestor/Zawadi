generator client {
  provider = "prisma-client-js"
}

// For production, change provider to "postgresql" and set both
// DATABASE_URL (Postgres connection string) and DATABASE_PROVIDER=postgresql
// in your environment. Then run: bunx prisma migrate deploy
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  phone         String?
  phoneVerified Boolean   @default(false)
  verifiedAt    DateTime?
  role          String    @default("user") // "user" | "business" | "admin"
  businessName  String?
  businessType  String?   // "agency" | "dealer" | "developer" | "other"
  referralCode  String?   @unique
  referredById  String?
  bannedAt      DateTime?
  notifyChat            Boolean @default(true)
  notifyMarketing       Boolean @default(false)
  notifySavedSearches   Boolean @default(true)
  preferredLang         String  @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  listings      Listing[]
  favorites     Favorite[]
  conversations ConversationParticipant[]
  messages      Message[]
  reviewsGiven    Review[] @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewSubject")
  reportsFiled    Report[] @relation("ReportReporter")
  reportsAgainst  Report[] @relation("ReportSubject")
  pushTokens      PushToken[]
  savedSearches   SavedSearch[]
  phoneVerifications PhoneVerification[]
  referrer        User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referred        User[]   @relation("UserReferrals")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Listing {
  id           String         @id @default(cuid())
  title        String
  description  String
  price        Float
  currency     String         @default("USD")
  category     String         // "property" | "land" | "car" | "mining" | "machinery"
  listingType  String         @default("sale") // "sale" | "rent"
  rentalPeriod String?        // "day" | "week" | "month" | "year"
  status       String         @default("active") // "active" | "sold" | "pending"
  country      String
  city         String?
  address      String?
  latitude     Float?
  longitude    Float?
  images       ListingImage[]
  favorites    Favorite[]
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Property & Land fields
  area         Float?
  bedrooms     Int?
  bathrooms    Int?
  propertyType String?        // "apartment" | "house" | "villa" | "commercial" | "farm" | "plot"

  // Car fields
  carMake      String?
  carModel     String?
  carYear      Int?
  carMileage   Int?
  carCondition String?        // "new" | "used" | "excellent" | "good" | "fair"
  carColor     String?
  carFuel      String?        // "petrol" | "diesel" | "electric" | "hybrid"

  // Mining site fields
  mineralType  String?        // "gold" | "diamond" | "copper" | "coal" | "platinum" | "other"
  miningArea   Float?
  miningLicense String?
  miningStatus  String?       // "active" | "dormant" | "prospect"

  // Machinery fields
  machineryKind  String?      // "agriculture" | "construction"
  machineryType  String?      // e.g. "backhoe" | "wheel_loader" | "excavator" | "tractor" | "combine" | ...
  machineryBrand String?      // e.g. "Caterpillar", "John Deere"
  machineryModel String?
  machineryYear  Int?
  machineryHours Int?
  machineryCondition String?  // "new" | "used" | "excellent" | "good" | "fair"

  // Features (stored as JSON string)
  features     String?

  // Boost (featured listing via payment provider)
  boosted       Boolean   @default(false)
  boostedUntil  DateTime?
  boostPayments BoostPayment[]

  viewCount     Int       @default(0)
  deletedAt     DateTime?  // soft delete

  // Moderation
  underReview   Boolean   @default(false)
  approvedAt    DateTime?

  conversations Conversation[]
  reports       Report[]
  priceHistory  PriceHistory[]
  views         ListingView[]
  boostVariants BoostVariant[]
  duplicates    ListingDuplicate[] @relation("ListingDupe")
  duplicateOf   ListingDuplicate[] @relation("OriginalDupe")

  @@index([status, category, createdAt])
  @@index([country, status])
  @@index([userId])
  @@index([boosted, boostedUntil])
  @@index([deletedAt])
  @@index([underReview])
}

model BoostPayment {
  id              String   @id @default(cuid())
  listingId       String
  listing         Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId          String
  provider        String   @default("paystack") // "paystack" | "flutterwave"
  txRef           String   @unique          // our reference sent to the provider
  providerTxId    String?                   // provider's transaction id after success
  amount          Float
  currency        String
  days            Int
  status          String   @default("pending") // "pending" | "successful" | "failed"
  createdAt       DateTime @default(now())
  verifiedAt      DateTime?
}

model ListingImage {
  id           String   @id @default(cuid())
  url          String
  order        Int      @default(0)
  listingId    String
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  // pHash for duplicate detection (16-char hex string from perceptual hash)
  pHash        String?
  // Sightengine moderation result, JSON-stringified
  moderation   String?
  createdAt    DateTime @default(now())

  @@index([pHash])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model Conversation {
  id            String                    @id @default(cuid())
  listingId     String?
  listing       Listing?                  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  participants  ConversationParticipant[]
  messages      Message[]
  lastMessageAt DateTime                  @default(now())
  createdAt     DateTime                  @default(now())

  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  // "text" | "offer" | "video-room"
  kind           String       @default("text")
  // For offers
  offerAmount    Float?
  offerCurrency  String?
  // "pending" | "accepted" | "declined" | "countered" | "expired"
  offerStatus    String?
  // For video-room: LiveKit room name
  videoRoom      String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  authorId  String
  subjectId String
  rating    Int
  body      String?
  createdAt DateTime @default(now())
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  subject   User     @relation("ReviewSubject", fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([authorId, subjectId])
  @@index([subjectId])
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  // Target: either a listing OR a user
  listingId   String?
  subjectId   String?
  reason      String   // "spam" | "scam" | "offensive" | "wrong_category" | "other"
  body        String?
  status      String   @default("open") // "open" | "reviewed" | "dismissed" | "actioned"
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  reporter    User     @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  subject     User?    @relation("ReportSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  listing     Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([listingId])
  @@index([subjectId])
}

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  name        String
  category    String?
  country     String?
  search      String?
  minPrice    Float?
  maxPrice    Float?
  listingType String?
  lastNotifiedAt DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PhoneVerification {
  id        String   @id @default(cuid())
  userId    String
  phone     String
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ListingView {
  id        String   @id @default(cuid())
  listingId String
  userId    String?
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
}

model PriceHistory {
  id        String   @id @default(cuid())
  listingId String
  oldPrice  Float
  newPrice  Float
  changedAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, changedAt])
}

model BoostVariant {
  id          String   @id @default(cuid())
  listingId   String
  label       String   // "A" | "B"
  title       String
  impressions Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model ListingDuplicate {
  id          String   @id @default(cuid())
  listingId   String   // suspected duplicate
  originalId  String   // earlier listing it matches
  similarity  Float    // 0..1
  createdAt   DateTime @default(now())
  listing     Listing  @relation("ListingDupe", fields: [listingId], references: [id], onDelete: Cascade)
  original    Listing  @relation("OriginalDupe", fields: [originalId], references: [id], onDelete: Cascade)

  @@unique([listingId, originalId])
  @@index([originalId])
}

model FeatureFlag {
  key       String   @id
  enabled   Boolean  @default(false)
  // 0..100 — percentage rollout
  rollout   Int      @default(100)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   // "ios" | "android" | "web"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
