generator client {
  provider = "prisma-client-js"
}

// For production, change provider to "postgresql" and set both
// DATABASE_URL (Postgres connection string) and DATABASE_PROVIDER=postgresql
// in your environment. Then run: bunx prisma migrate deploy
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  phone         String?
  phoneVerified Boolean   @default(false)
  verifiedAt    DateTime?
  role          String    @default("user") // "user" | "business" | "admin"
  businessName  String?
  businessType  String?   // "agency" | "dealer" | "developer" | "other"
  referralCode  String?   @unique
  referredById  String?
  bannedAt      DateTime?
  notifyChat            Boolean @default(true)
  notifyMarketing       Boolean @default(false)
  notifySavedSearches   Boolean @default(true)
  preferredLang         String  @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  listings      Listing[]
  favorites     Favorite[]
  conversations ConversationParticipant[]
  messages      Message[]
  reviewsGiven    Review[] @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewSubject")
  reportsFiled    Report[] @relation("ReportReporter")
  reportsAgainst  Report[] @relation("ReportSubject")
  pushTokens      PushToken[]
  savedSearches   SavedSearch[]
  phoneVerifications PhoneVerification[]
  referrer        User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referred        User[]   @relation("UserReferrals")

  // Marketplace transactions
  wallet          Wallet?
  walletTopups    WalletTopup[]
  kyc             Kyc?
  buyerTrades     Trade[]    @relation("BuyerTrades")
  sellerTrades   Trade[]    @relation("SellerTrades")
  bids            Bid[]
  withdrawals     Withdrawal[]
  webhooks        Webhook[]
  apiKeys         ApiKey[]
  totp            TotpSecret?
  // Denormalised counters for cheap badges
  tradeCount      Int        @default(0)
  ratingSum       Int        @default(0)
  ratingCount     Int        @default(0)
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Listing {
  id           String         @id @default(cuid())
  title        String
  description  String
  price        Float
  currency     String         @default("USD")
  category     String         // "property" | "land" | "car" | "mining" | "machinery"
  listingType  String         @default("sale") // "sale" | "rent"
  rentalPeriod String?        // "day" | "week" | "month" | "year"
  status       String         @default("active") // "active" | "sold" | "pending"
  country      String
  city         String?
  address      String?
  latitude     Float?
  longitude    Float?
  images       ListingImage[]
  favorites    Favorite[]
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Property & Land fields
  area         Float?
  bedrooms     Int?
  bathrooms    Int?
  propertyType String?        // "apartment" | "house" | "villa" | "commercial" | "farm" | "plot"

  // Car fields
  carMake      String?
  carModel     String?
  carYear      Int?
  carMileage   Int?
  carCondition String?        // "new" | "used" | "excellent" | "good" | "fair"
  carColor     String?
  carFuel      String?        // "petrol" | "diesel" | "electric" | "hybrid"

  // Mining site fields
  mineralType  String?        // "gold" | "diamond" | "copper" | "coal" | "platinum" | "other"
  miningArea   Float?
  miningLicense String?
  miningStatus  String?       // "active" | "dormant" | "prospect"

  // Machinery fields
  machineryKind  String?      // "agriculture" | "construction"
  machineryType  String?      // e.g. "backhoe" | "wheel_loader" | "excavator" | "tractor" | "combine" | ...
  machineryBrand String?      // e.g. "Caterpillar", "John Deere"
  machineryModel String?
  machineryYear  Int?
  machineryHours Int?
  machineryCondition String?  // "new" | "used" | "excellent" | "good" | "fair"

  // Features (stored as JSON string)
  features     String?

  // Boost (featured listing via payment provider)
  boosted       Boolean   @default(false)
  boostedUntil  DateTime?
  boostPayments BoostPayment[]

  viewCount     Int       @default(0)
  deletedAt     DateTime?  // soft delete

  // Moderation
  underReview   Boolean   @default(false)
  approvedAt    DateTime?

  // Auction support — when auctionEndsAt is set, the listing accepts bids.
  // minBid / reservePrice / bidIncrement are in minor units of `currency`.
  auctionEndsAt DateTime?
  minBid        Int?
  reservePrice  Int?
  bidIncrement  Int?
  auctionClosed Boolean   @default(false)

  conversations Conversation[]
  reports       Report[]
  priceHistory  PriceHistory[]
  views         ListingView[]
  boostVariants BoostVariant[]
  duplicates    ListingDuplicate[] @relation("ListingDupe")
  duplicateOf   ListingDuplicate[] @relation("OriginalDupe")
  bids          Bid[]
  trades        Trade[]

  @@index([status, category, createdAt])
  @@index([country, status])
  @@index([userId])
  @@index([boosted, boostedUntil])
  @@index([deletedAt])
  @@index([underReview])
  @@index([auctionEndsAt, auctionClosed])
}

model BoostPayment {
  id              String   @id @default(cuid())
  listingId       String
  listing         Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId          String
  provider        String   @default("paystack") // "paystack" | "flutterwave"
  txRef           String   @unique          // our reference sent to the provider
  providerTxId    String?                   // provider's transaction id after success
  amount          Float
  currency        String
  days            Int
  status          String   @default("pending") // "pending" | "successful" | "failed"
  createdAt       DateTime @default(now())
  verifiedAt      DateTime?
}

model ListingImage {
  id           String   @id @default(cuid())
  url          String
  order        Int      @default(0)
  listingId    String
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  // pHash for duplicate detection (16-char hex string from perceptual hash)
  pHash        String?
  // Sightengine moderation result, JSON-stringified
  moderation   String?
  createdAt    DateTime @default(now())

  @@index([pHash])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model Conversation {
  id            String                    @id @default(cuid())
  listingId     String?
  listing       Listing?                  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  participants  ConversationParticipant[]
  messages      Message[]
  lastMessageAt DateTime                  @default(now())
  createdAt     DateTime                  @default(now())

  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  // "text" | "offer" | "video-room"
  kind           String       @default("text")
  // For offers
  offerAmount    Float?
  offerCurrency  String?
  // "pending" | "accepted" | "declined" | "countered" | "expired"
  offerStatus    String?
  // For video-room: LiveKit room name
  videoRoom      String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  authorId  String
  subjectId String
  rating    Int
  body      String?
  // When set, this review is anchored to a completed trade and carries
  // extra trust signal. Trade-anchored reviews cannot be re-edited freely.
  tradeId   String?  @unique
  createdAt DateTime @default(now())
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  subject   User     @relation("ReviewSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  trade     Trade?   @relation(fields: [tradeId], references: [id], onDelete: SetNull)

  @@unique([authorId, subjectId])
  @@index([subjectId])
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  // Target: either a listing OR a user
  listingId   String?
  subjectId   String?
  reason      String   // "spam" | "scam" | "offensive" | "wrong_category" | "other"
  body        String?
  status      String   @default("open") // "open" | "reviewed" | "dismissed" | "actioned"
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  reporter    User     @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  subject     User?    @relation("ReportSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  listing     Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([listingId])
  @@index([subjectId])
}

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  name        String
  category    String?
  country     String?
  search      String?
  minPrice    Float?
  maxPrice    Float?
  listingType String?
  lastNotifiedAt DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PhoneVerification {
  id        String   @id @default(cuid())
  userId    String
  phone     String
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ListingView {
  id        String   @id @default(cuid())
  listingId String
  userId    String?
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
}

model PriceHistory {
  id        String   @id @default(cuid())
  listingId String
  oldPrice  Float
  newPrice  Float
  changedAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, changedAt])
}

model BoostVariant {
  id          String   @id @default(cuid())
  listingId   String
  label       String   // "A" | "B"
  title       String
  impressions Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model ListingDuplicate {
  id          String   @id @default(cuid())
  listingId   String   // suspected duplicate
  originalId  String   // earlier listing it matches
  similarity  Float    // 0..1
  createdAt   DateTime @default(now())
  listing     Listing  @relation("ListingDupe", fields: [listingId], references: [id], onDelete: Cascade)
  original    Listing  @relation("OriginalDupe", fields: [originalId], references: [id], onDelete: Cascade)

  @@unique([listingId, originalId])
  @@index([originalId])
}

model FeatureFlag {
  key       String   @id
  enabled   Boolean  @default(false)
  // 0..100 — percentage rollout
  rollout   Int      @default(100)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   // "ios" | "android" | "web"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// -------- Marketplace transactions (internal payment + escrow + trades) --------

// Each user gets a single Wallet per currency snapshot. Money is stored as
// integer minor units (cents/kobo/RWF). `pendingDebit` tracks money the user
// has committed but not yet settled (e.g. buyer paid into escrow); the actual
// balance is decremented at the moment of the debit and refunded on
// cancellation. `pendingCredit` tracks money owed to the user that hasn't
// settled yet (e.g. seller has delivered but buyer hasn't confirmed).
model Wallet {
  id            String      @id @default(cuid())
  userId        String      @unique
  balance       Int         @default(0)
  pendingDebit  Int         @default(0)
  pendingCredit Int         @default(0)
  currency      String      @default("USD")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  WalletTxn[]
}

// Append-only ledger. Never UPDATE a row — only insert reversing entries.
model WalletTxn {
  id          String   @id @default(cuid())
  walletId    String
  // "deposit" | "withdraw" | "transfer_in" | "transfer_out" |
  // "escrow_hold" | "escrow_release" | "escrow_refund" | "fee" | "boost"
  kind        String
  // Positive credits, negative debits. Same currency as the wallet.
  amount      Int
  currency    String
  // What this entry relates to.
  refType     String?  // "trade" | "topup" | "boost" | "external"
  refId       String?
  status      String   @default("posted") // "posted" | "reversed"
  description String?
  createdAt   DateTime @default(now())
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([refType, refId])
}

// External top-ups (Pesapal etc.) before they're credited to the wallet.
model WalletTopup {
  id           String   @id @default(cuid())
  userId       String
  provider     String   @default("pesapal")
  providerRef  String?  @unique
  txRef        String   @unique
  amount       Int
  currency     String
  status       String   @default("pending") // "pending" | "successful" | "failed"
  createdAt    DateTime @default(now())
  creditedAt   DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// KYC / identity verification — one record per user. Gates high-value trades
// and business upgrades when env.KYC_REQUIRED_OVER_USD is exceeded.
model Kyc {
  id              String    @id @default(cuid())
  userId          String    @unique
  legalName       String?
  dob             DateTime?
  country         String?
  idType          String?   // "passport" | "national_id" | "driving_license"
  idNumber        String?
  idFrontUrl      String?
  idBackUrl       String?
  selfieUrl       String?
  // "unsubmitted" | "pending" | "approved" | "rejected"
  status          String    @default("unsubmitted")
  rejectionReason String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedById    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sanctionsHits   SanctionsHit[]

  @@index([status])
}

// A Trade ties a Buyer + Seller + Listing + Amount together. State machine:
//   initiated -> funded -> in_escrow -> delivered -> completed
//                            \-> disputed
//                            \-> refunded
//                            \-> cancelled (only before in_escrow)
model Trade {
  id          String    @id @default(cuid())
  listingId   String
  buyerId     String
  sellerId    String
  amount      Int
  currency    String
  feeAmount   Int       @default(0)
  taxAmount   Int       @default(0)
  taxRateBps  Int       @default(0)
  riskScore   Int       @default(0)
  releaseDueAt DateTime?     // auto-release escrow at/after this if not disputed/confirmed
  receiptUrl  String?
  status      String    @default("initiated")
  fundedAt    DateTime?
  escrowedAt  DateTime?
  deliveredAt DateTime?
  completedAt DateTime?
  refundedAt  DateTime?
  cancelledAt DateTime?
  // Optional smart-contract anchor (off-chain content + on-chain anchor)
  contractId  String?   @unique
  // If this trade originated from an auction bid
  bidId       String?   @unique
  // Chain anchor info for the trade lifecycle
  chainAddress String?  // factory address used
  chainName    String?
  chainTradeId String?  // bytes32 hex used as the on-chain key
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  listing     Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer       User      @relation("BuyerTrades", fields: [buyerId], references: [id], onDelete: Cascade)
  seller      User      @relation("SellerTrades", fields: [sellerId], references: [id], onDelete: Cascade)
  contract    Contract? @relation(fields: [contractId], references: [id])
  bid         Bid?      @relation(fields: [bidId], references: [id])
  review      Review?
  events      TradeEvent[]
  splits      TradeSplit[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([status])
}

// Append-only event log per trade — drives the timeline UI.
model TradeEvent {
  id          String   @id @default(cuid())
  tradeId     String
  kind        String   // matches Trade.status transitions
  actorId     String?  // user who triggered the event (null = system)
  note        String?
  // Optional on-chain tx that anchored this event
  chainTxHash String?
  chainName   String?
  createdAt   DateTime @default(now())
  trade       Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId, createdAt])
}

// "Smart" contract — really an off-chain signed agreement we can optionally
// anchor to a public chain by recording a transaction hash. The terms field
// is the authoritative content; chainTxHash + contentHash give third parties
// a way to verify it post-hoc.
model Contract {
  id             String    @id @default(cuid())
  terms          String
  // sha256 hex of the canonicalised terms
  contentHash    String?
  // Optional chain network and tx hash. We never call out to a chain from
  // here — record whatever the user/operator pastes after anchoring.
  chain          String?   // "polygon" | "stellar" | "hedera" | ...
  chainTxHash    String?
  buyerId        String
  sellerId       String
  // "draft" | "signed_buyer" | "signed_seller" | "active" | "executed" | "voided"
  status         String    @default("draft")
  buyerSignedAt  DateTime?
  sellerSignedAt DateTime?
  executedAt     DateTime?
  // Chain anchors per signature
  buyerSignTxHash  String?
  sellerSignTxHash String?
  createTxHash     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  trade          Trade?

  @@index([buyerId])
  @@index([sellerId])
}

// Auction bids.
model Bid {
  id         String   @id @default(cuid())
  listingId  String
  bidderId   String
  amount     Int      // minor units
  currency   String
  // Optional max bid for proxy bidding.
  maxAmount  Int?
  // "active" | "outbid" | "won" | "withdrawn" | "rejected"
  status     String   @default("active")
  // When non-null, an escrow_hold txn was posted to the bidder's wallet for
  // this bid. We refund it when the bid is outbid / withdrawn / rejected.
  holdTxnId  String?
  createdAt  DateTime @default(now())
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bidder     User     @relation(fields: [bidderId], references: [id], onDelete: Cascade)
  trade      Trade?

  @@index([listingId, amount])
  @@index([bidderId])
}

// --- Withdrawals: ops queue. The wallet is debited immediately; payout is
//     completed manually or via a payouts API and marked here. On failure,
//     ops calls /admin/withdrawals/:id/fail which reverses the debit.
model Withdrawal {
  id          String   @id @default(cuid())
  userId      String
  walletTxnId String?  @unique
  amount      Int
  currency    String
  method      String   // "mobile_money" | "bank"
  phone       String?
  bankName    String?
  bankAccount String?
  status      String   @default("pending") // "pending" | "paid" | "failed"
  providerRef String?
  failureReason String?
  createdAt   DateTime @default(now())
  paidAt      DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

// --- Outbound webhooks (signed). Subscribed events list is comma-separated.
model Webhook {
  id        String   @id @default(cuid())
  ownerId   String
  url       String
  secret    String   // primary HMAC secret
  // Secondary secret active during a rotation overlap window. When set, we
  // include BOTH signatures in outbound deliveries so subscribers can rotate
  // without dropping events. Subscribers should accept either v1=... value.
  secretPrev String?
  secretRotatedAt DateTime?
  events    String   // CSV of event names
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([ownerId])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String
  event       String
  payload     String   // JSON
  status      String   @default("pending") // "pending" | "delivered" | "failed"
  attempts    Int      @default(0)
  responseCode Int?
  responseBody String?
  nextAttemptAt DateTime?
  lastAttemptAt DateTime?
  createdAt   DateTime @default(now())
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([webhookId, createdAt])
}

// --- Append-only audit log. Every admin or system-side action lands here.
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String   // e.g. "trade.refund", "kyc.approve"
  target    String?  // e.g. "trade", "user"
  targetId  String?
  ip        String?
  userAgent String?
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([target, targetId])
}

// --- API keys for partner integrations. Prefix is the visible label; only
//     the hash is stored. Scopes is CSV: "listings:read,trades:read".
model ApiKey {
  id         String   @id @default(cuid())
  userId     String
  name       String
  prefix     String   @unique
  hash       String
  scopes     String   @default("")
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// --- Idempotency keys for mutating endpoints. Stores the response body so
//     callers that retry with the same key get the same result back.
model IdempotencyKey {
  key        String   @id
  userId     String?
  method     String
  path       String
  status     Int
  response   String   // JSON body
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}

// --- TOTP 2FA. We use 30-second window, SHA-1 (RFC 6238 default) so any
//     authenticator app works. Activated when verifiedAt is set.
model TotpSecret {
  userId     String   @id
  secret     String
  verifiedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- Sanctions hit cache. We keep matched names/IDs per KYC submission so
//     admins can re-review without re-querying the upstream feed.
model SanctionsHit {
  id        String   @id @default(cuid())
  kycId    String
  source   String   // "OFAC_SDN" | "UN" | "EU" | "custom"
  score    Float
  matchedName String
  details  String?  // JSON
  createdAt DateTime @default(now())
  kyc      Kyc      @relation(fields: [kycId], references: [id], onDelete: Cascade)

  @@index([kycId])
}

// --- Trade payout splits: optionally fan out a seller's net to N parties.
//     Percentages are basis points (10000 = 100%). The Sum across all rows
//     for a trade must be 10000 or the release falls back to "all to seller".
model TradeSplit {
  id          String   @id @default(cuid())
  tradeId     String
  payeeUserId String
  bps         Int      // basis points of net
  note        String?
  paidAt      DateTime?
  trade       Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@index([payeeUserId])
}
