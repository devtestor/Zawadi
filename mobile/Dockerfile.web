# Build the Expo web export, then ship it inside Caddy for static serving.
# Used by docker-compose.prod.yml as the `web` service. The container only
# serves files — TLS is terminated by the outer Caddy reverse-proxy.

# ---- build ----
# Debian-slim base for the build stage — apt mirrors are far more reliable
# than dl-cdn.alpinelinux.org which intermittently 5xxs.
# bun 1.3+ required — `bunx expo export` hangs indefinitely on 1.2 (verified
# in CI: 6 h timeout vs. ~45 s on bun 1.3 locally).
FROM oven/bun:1.3-slim AS build
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends \
      git python3 make g++ ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install dependencies first for better cache reuse.
COPY package.json bun.lock ./
COPY patches ./patches
RUN bun install --frozen-lockfile

# Backend URL gets baked into the JS bundle, so it must be supplied at build
# time. CI passes this from a repo variable; bootstrap defaults to localhost.
ARG EXPO_PUBLIC_BACKEND_URL=http://localhost:3000
ENV EXPO_PUBLIC_BACKEND_URL=$EXPO_PUBLIC_BACKEND_URL

# Copy the rest and emit a static web export.
COPY . .
ENV NODE_ENV=production
RUN bunx expo export --platform web --output-dir dist

# ---- runtime ----
# Caddy stays on Alpine — the runtime is cached/pulled, not built, so the
# transient apk issue doesn't apply here.
FROM caddy:2-alpine AS runtime
COPY --from=build /app/dist /srv
# Tiny Caddyfile: SPA fallback to index.html, gzip, long cache on hashed assets.
RUN cat > /etc/caddy/Caddyfile <<'EOF'
:80 {
  root * /srv
  encode zstd gzip
  @assets path *.js *.css *.png *.jpg *.jpeg *.gif *.svg *.woff *.woff2 *.ttf *.ico
  header @assets Cache-Control "public, max-age=31536000, immutable"
  header /index.html Cache-Control "no-cache"
  try_files {path} /index.html
  file_server
}
EOF
EXPOSE 80
