{
  "expo": {
    "name": "ZAWADI",
    "slug": "zawadi",
    "scheme": "zawadi",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.zawadi.marketplace"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "app.zawadi.marketplace"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D4A843"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
