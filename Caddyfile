# Reverse-proxy + automatic Let's Encrypt for the API.
# `{$DOMAIN}` is templated from the compose env so the same file works for
# any deployment.

{$DOMAIN} {
  encode zstd gzip

  # Security headers
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "geolocation=(self), microphone=()"
    -Server
  }

  # Cap upload sizes at the edge so leaked stack traces don't carry payloads.
  request_body {
    max_size 12MB
  }

  reverse_proxy backend:3000 {
    health_uri /health
    health_interval 10s
    health_timeout 3s
  }

  log {
    output stdout
    format console
  }
}
