# Reverse-proxy + automatic Let's Encrypt for the API + Web hosts.
# Hostnames are templated from compose env so the same file works for any
# deployment.

(common_headers) {
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "geolocation=(self), microphone=()"
    -Server
  }
}

# --- API ---
{$API_DOMAIN} {
  encode zstd gzip
  import common_headers

  request_body {
    max_size 12MB
  }

  reverse_proxy backend:3000 {
    health_uri /health
    health_interval 10s
    health_timeout 3s
  }

  log {
    output stdout
    format console
  }
}

# --- Web (Expo static export) ---
{$WEB_DOMAIN} {
  encode zstd gzip
  import common_headers

  reverse_proxy web:80

  log {
    output stdout
    format console
  }
}
